---
import MobileTableOfContents from 'virtual:starlight/components/MobileTableOfContents';
import TableOfContents from 'virtual:starlight/components/TableOfContents';
import HeartLike from './HeartLike.astro';

const { entry, toc } = Astro.locals.starlightRoute;
const slug = entry.slug || 'index';
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const heartEnabled = Boolean(supabaseUrl && supabaseKey);
---

{
	toc && (
		<>
			<div class="lg:sl-hidden">
				{heartEnabled && <HeartLike />}
				<MobileTableOfContents />
			</div>
			<div class="right-sidebar-panel sl-hidden lg:sl-block">
				<div class="sl-container">
					{heartEnabled && <HeartLike />}
					<TableOfContents />
				</div>
			</div>
		</>
	)
}

{
	heartEnabled && (
		<script define:vars={{ slug, supabaseUrl, supabaseKey }}>
			(() => {
				const containers = Array.from(document.querySelectorAll('.heart-like'));
				if (containers.length === 0) return;
				const buttons = containers.map((c) => c.querySelector('button'));
				const countEls = containers.map((c) => c.querySelector('.count'));
				const storageKey = 'odio-liked:' + slug;
				const baseUrl = supabaseUrl.replace(/\/$/, '');
				const headers = { apikey: supabaseKey, Authorization: 'Bearer ' + supabaseKey };

				let liked = localStorage.getItem(storageKey) === '1';
				let count = 0;
				let inFlight = false;
				let ready = false;

				const render = () => {
					buttons.forEach((b) => {
						b.setAttribute('aria-pressed', liked ? 'true' : 'false');
						b.classList.toggle('liked', liked);
						b.disabled = !ready || inFlight;
					});
					countEls.forEach((el) => {
						el.textContent = String(count);
					});
				};

				fetch(
					baseUrl +
						'/rest/v1/page_likes?slug=eq.' +
						encodeURIComponent(slug) +
						'&select=count',
					{ headers }
				)
					.then((r) => (r.ok ? r.json() : []))
					.then((rows) => {
						count = rows[0]?.count ?? 0;
						ready = true;
						render();
					})
					.catch(() => {
						ready = true;
						render();
					});

				const onClick = async () => {
					if (!ready || inFlight) return;
					inFlight = true;
					const nextLiked = !liked;
					liked = nextLiked;
					count = Math.max(0, count + (nextLiked ? 1 : -1));
					render();
					try {
						const res = await fetch(baseUrl + '/rest/v1/rpc/toggle_like', {
							method: 'POST',
							headers: { ...headers, 'Content-Type': 'application/json' },
							body: JSON.stringify({ page_slug: slug, liked: nextLiked }),
						});
						if (!res.ok) throw new Error('toggle_like failed');
						const newCount = await res.json();
						if (typeof newCount === 'number') count = newCount;
						if (nextLiked) localStorage.setItem(storageKey, '1');
						else localStorage.removeItem(storageKey);
					} catch (e) {
						liked = !nextLiked;
						count = Math.max(0, count + (nextLiked ? -1 : 1));
					} finally {
						inFlight = false;
						render();
					}
				};

				buttons.forEach((b) => b.addEventListener('click', onClick));
				render();
			})();
		</script>
	)
}

<style>
	@layer starlight.core {
		.right-sidebar-panel {
			padding: 1rem var(--sl-sidebar-pad-x);
		}
		.sl-container {
			width: calc(var(--sl-sidebar-width) - 2 * var(--sl-sidebar-pad-x));
		}
		.right-sidebar-panel :global(h2) {
			color: var(--sl-color-white);
			font-size: var(--sl-text-h5);
			font-weight: 600;
			line-height: var(--sl-line-height-headings);
			margin-bottom: 0.5rem;
		}
		.right-sidebar-panel :global(:where(a)) {
			display: block;
			font-size: var(--sl-text-xs);
			text-decoration: none;
			color: var(--sl-color-gray-3);
			overflow-wrap: anywhere;
		}
		.right-sidebar-panel :global(:where(a):hover) {
			color: var(--sl-color-white);
		}
		@media (min-width: 72rem) {
			.sl-container {
				max-width: calc(
					(
							(
									100vw - var(--sl-sidebar-width) - 2 * var(--sl-content-pad-x) - 2 *
										var(--sl-sidebar-pad-x)
								) * 0.25
						)
				);
			}
		}
	}
</style>
